{
  "name": "roman-numerals-encoder",
  "version": "1.0.0",
  "description": "Coding kata challenge for encoding decimal numbers up to 3999 as Roman numerals (standard notation)",
  "homepage": "https://github.com/jameshill-webdev/roman-numerals-encoder#readme",
  "bugs": {
    "url": "https://github.com/jameshill-webdev/roman-numerals-encoder/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jameshill-webdev/roman-numerals-encoder.git"
  },
  "license": "ISC",
  "author": "James Hill",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && shx cp src/index.html dist/index.html && shx cp src/main.css dist/main.css",
    "typecheck": "tsc --noEmit",
    "start": "npm run start:node",
    "start:node": "npm run build && node dist/index.js",
    "start:browser": "npm run build && http-server ./dist -c-1",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "http-server": "^14.1.1",
    "shx": "^0.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
